//----------------------- Set London coordinates -------------------------
var london_point = ee.Geometry.Point([-0.1276, 51.5072]);

Map.centerObject(london_point, 10)



//------------------------- Load vector data -----------------------------

// London GLA boundaries
var london_gla_boundary = ee.FeatureCollection("users/christychoicc/London_GLA_Boundary");

// London LSOA boundaries
var lsoa_london_boundary_raw = ee.FeatureCollection("users/christychoicc/lsoa_london");




// ----------------------- Clean LSOA geometry----------------------------

// Define a cleaning function
function cleanToPolygonOnly(feature) {
  // Check geometry of each LSOA (Polygon/ MultiPolygon/ Geometry Collection...)
  feature = ee.Feature(feature);
  var geom = feature.geometry();
  var geomType = geom.type();

  var polygonCoords = ee.List(
    // If is already a Polygon, keep and convert to MultiPolygon coordinate list
    ee.Algorithms.If(
      ee.Algorithms.IsEqual(geomType, 'Polygon'),
      ee.List([geom.coordinates()]),
      
      // If is MultiPolygon, keep coordinates
      ee.Algorithms.If(
        ee.Algorithms.IsEqual(geomType, 'MultiPolygon'),
        geom.coordinates(),

        // If is GeometryCollection, keep only Polygon/ MultiPolygon
        ee.List(geom.geometries()).iterate(function(part, acc) {
          part = ee.Geometry(part);
          acc = ee.List(acc);

          var partType = part.type();

          var coordsToAdd = ee.List(
            // Keep Polygon
            ee.Algorithms.If(
              ee.Algorithms.IsEqual(partType, 'Polygon'),
              ee.List([part.coordinates()]),
              // Keep MultiPolygon
              ee.Algorithms.If(
                ee.Algorithms.IsEqual(partType, 'MultiPolygon'),
                part.coordinates(),

                // Drop any LineString, Point...
                ee.List([])
              )
            )
          );

          return acc.cat(coordsToAdd);
        }, ee.List([]))
      )
    )
  );
  // Create as a MultiPolygon with polygons only (no LineStrings)
  var cleanGeom = ee.Geometry.MultiPolygon(polygonCoords, null, false);

  return ee.Feature(cleanGeom)
    .copyProperties(feature)
    .set('clean_geom_type', cleanGeom.type())
    .set('n_polygon_parts', polygonCoords.length());
}

// Apply the cleaning function to all LSOAs
var lsoa_london_boundary = lsoa_london_boundary_raw
  .map(cleanToPolygonOnly)
  .filter(ee.Filter.gt('n_polygon_parts', 0));


// Check after cleaning
